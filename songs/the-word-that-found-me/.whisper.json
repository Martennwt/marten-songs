689453},{"word":"I","start":239.9199981689453,"end":240.94000244140625},{"word":"finally","start":240.94000244140625,"end":241.5399932861328},{"word":"found","start":241.5399932861328,"end":242.47999572753906}],"segments":[{"id":0,"seek":0,"start":22.65999984741211,"end":29.979999542236328,"text":" me through the night, and the fear I couldn't carry, He took the weight I couldn't hold and He carried it for me.","tokens":[50364,385,807,264,1818,11,293,264,4240,286,2809,380,3985,11,634,1890,264,3364,286,2809,380,1797,293,634,9094,309,337,385,13,50714],"temperature":0,"avg_logprob":-0.7917332649230957,"compression_ratio":1.255555510520935,"no_speech_prob":0.5057374835014343},{"id":1,"seek":3000,"start":30,"end":53.599998474121094,"text":" I had carried all my worry till my shoulders nearly broke, and I whispered to the silence with the little faith I spoke. It was smaller than a mustard seed, it was barely even there, but it turned me toward the only light still burning anywhere.","tokens":[50364,286,632,9094,439,452,3292,4288,452,10245,6217,6902,11,293,286,26018,292,281,264,12239,365,264,707,4522,286,7179,13,467,390,4356,813,257,23659,8871,11,309,390,10268,754,456,11,457,309,3574,385,7361,264,787,1442,920,9488,4992,13,51564],"temperature":0,"avg_logprob":-0.25510212779045105,"compression_ratio":1.5123456716537476,"no_speech_prob":0.9585777521133423},{"id":2,"seek":5360,"start":53.599998474121094,"end":79.9800033569336,"text":" I was empty, I was lonely, with the dark on every side, when a voice said, open up the Word, and I had nowhere left to hide. So I read it in the silence and the words began to shine, and the fear I couldn't carry, He was trading line by line.","tokens":[50414,286,390,6707,11,286,390,14236,11,365,264,2877,322,633,1252,11,562,257,3177,848,11,1269,493,264,8725,11,293,286,632,11159,1411,281,6479,13,407,286,1401,309,294,264,12239,293,264,2283,4283,281,12207,11,293,264,4240,286,2809,380,3985,11,634,390,9529,1622,538,1622,13,51664],"temperature":0,"avg_logprob":-0.19190935790538788,"compression_ratio":1.4756097793579102,"no_speech_prob":0.9568254947662354},{"id":3,"seek":7998,"start":79.9800033569336,"end":93.80000305175781,"text":" Now there's peace I cannot explain where the worry used to be, He took the weight I couldn't hold and He carried it for me.","tokens":[50364,823,456,311,4336,286,2644,2903,689,264,3292,1143,281,312,11,634,1890,264,3364,286,2809,380,1797,293,634,9094,309,337,385,13,51064],"temperature":0,"avg_logprob":-0.1836501806974411,"compression_ratio":1.1941747665405273,"no_speech_prob":0.9200910329818726},{"id":4,"seek":9380,"start":94.80000305175781,"end":120.13999938964844,"text":" So I read it in the morning and I read it in the night, and the words I almost gave up on began to set me right. Every promise like a hand held out to pull me from the deep, come to me, you weary one, and He gave me rest to keep.","tokens":[50414,407,286,1401,309,294,264,2446,293,286,1401,309,294,264,1818,11,293,264,2283,286,1920,2729,493,322,4283,281,992,385,558,13,2048,6228,411,257,1011,5167,484,281,2235,385,490,264,2452,11,808,281,385,11,291,47853,472,11,293,634,2729,385,1472,281,1066,13,51664],"temperature":0,"avg_logprob":-0.17937760055065155,"compression_ratio":1.5266666412353516,"no_speech_prob":0.9731419086456299},{"id":5,"seek":12014,"start":120.13999938964844,"end":146.5,"text":" I was empty, I was lonely, with the dark on every side, when a voice said, open up the Word, and I had nowhere left to hide. So I read it in the silence and the words began to shine, and the fear I couldn't carry, He was trading line by line.","tokens":[50364,286,390,6707,11,286,390,14236,11,365,264,2877,322,633,1252,11,562,257,3177,848,11,1269,493,264,8725,11,293,286,632,11159,1411,281,6479,13,407,286,1401,309,294,264,12239,293,264,2283,4283,281,12207,11,293,264,4240,286,2809,380,3985,11,634,390,9529,1622,538,1622,13,51664],"temperature":0,"avg_logprob":-0.1484522968530655,"compression_ratio":1.4756097793579102,"no_speech_prob":0.9603981375694275},{"id":6,"seek":14650,"start":146.5,"end":159.1999969482422,"text":" Now there's peace I cannot explain where the worry used to be, He took the weight I couldn't hold and He carried it for me.","tokens":[50364,823,456,311,4336,286,2644,2903,689,264,3292,1143,281,312,11,634,1890,264,3364,286,2809,380,1797,293,634,9094,309,337,385,13,51014],"temperature":0,"avg_logprob":-0.17460496723651886,"compression_ratio":1.1941747665405273,"no_speech_prob":0.9080158472061157},{"id":7,"seek":15920,"start":160.55999755859375,"end":173.8800048828125,"text":" I don't have a faith of mountains, I just have a faith of seas, but it found me in the wreckage and it gave me what I need.","tokens":[50414,286,500,380,362,257,4522,295,10233,11,286,445,362,257,4522,295,22535,11,457,309,1352,385,294,264,21478,609,293,309,2729,385,437,286,643,13,51064],"temperature":0,"avg_logprob":-0.16384312510490417,"compression_ratio":1.6357616186141968,"no_speech_prob":0.9519189596176147},{"id":8,"seek":15920,"start":174.24000549316406,"end":186.86000061035156,"text":" And I'm grateful for the morning, I'm grateful for the gift, for the hand that took my fear away and gave me peace to live.","tokens":[51064,400,286,478,7941,337,264,2446,11,286,478,7941,337,264,5306,11,337,264,1011,300,1890,452,4240,1314,293,2729,385,4336,281,1621,13,51764],"temperature":0,"avg_logprob":-0.16384312510490417,"compression_ratio":1.6357616186141968,"no_speech_prob":0.9519189596176147},{"id":9,"seek":18686,"start":186.86000061035156,"end":201.4600067138672,"text":" I was empty, I was lonely, with the dark on every side, when a voice said, open up the Word, and I had nowhere left to hide.","tokens":[50414,286,390,6707,11,286,390,14236,11,365,264,2877,322,633,1252,11,562,257,3177,848,11,1269,493,264,8725,11,293,286,632,11159,1411,281,6479,13,51064],"temperature":0,"avg_logprob":-0.13721810281276703,"compression_ratio":1.2277227640151978,"no_speech_prob":0.9269397258758545},{"id":10,"seek":20146,"start":201.46000