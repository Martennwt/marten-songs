6.39999389648438,"end":186.4199981689453}],"segments":[{"id":0,"seek":0,"start":7.380000114440918,"end":22.100000381469727,"text":" The smallest of all the seeds, almost nothing in your hand, but you bury it one morning and it rises from the land.","tokens":[50414,440,16998,295,439,264,9203,11,1920,1825,294,428,1011,11,457,291,28919,309,472,2446,293,309,21373,490,264,2117,13,51464],"temperature":0,"avg_logprob":-0.36961811780929565,"compression_ratio":1.25,"no_speech_prob":0.2960079610347748},{"id":1,"seek":2210,"start":22.100000381469727,"end":33.119998931884766,"text":" They say a faith that small could move a mountain to the sea, so I'll hold my little handful and I'll see what it can be.","tokens":[50364,814,584,257,4522,300,1359,727,1286,257,6937,281,264,4158,11,370,286,603,1797,452,707,16458,293,286,603,536,437,309,393,312,13,50914],"temperature":0,"avg_logprob":-0.154298797249794,"compression_ratio":1.4629629850387573,"no_speech_prob":0.7920628786087036},{"id":2,"seek":2210,"start":33.36000061035156,"end":43.81999969482422,"text":" Even faith like a mustard seed is faith enough to grow, I believe, help my unbelief, that's the only prayer I know.","tokens":[50914,2754,4522,411,257,23659,8871,307,4522,1547,281,1852,11,286,1697,11,854,452,46063,2521,11,300,311,264,787,8767,286,458,13,51464],"temperature":0,"avg_logprob":-0.154298797249794,"compression_ratio":1.4629629850387573,"no_speech_prob":0.7920628786087036},{"id":3,"seek":4382,"start":43.81999969482422,"end":55.060001373291016,"text":" When the doubt rolls in like weather, I will hold on all the same, cause it's not how tight I'm holding, it's the One who holds my name.","tokens":[50364,1133,264,6385,15767,294,411,5503,11,286,486,1797,322,439,264,912,11,3082,309,311,406,577,4524,286,478,5061,11,309,311,264,1485,567,9190,452,1315,13,50914],"temperature":0,"avg_logprob":-0.21967704594135284,"compression_ratio":1.5197739601135254,"no_speech_prob":0.8432407379150391},{"id":4,"seek":4382,"start":60.080001831054